rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Root doc holds { email, uid, allowed } — readable/writable by owner.
      // NOTE: `allowed` is a UX gate only; the real security boundary is the
      // member-only trip rules below.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /profile/data {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      // Own traveler directory (ProfileContext)
      match /travelers/data {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ── Trips — member-only, with one scoped exception for share-link joins ─
    match /trips/{tripId} {
      function memberIds() {
        return resource.data.get('memberIds', []);
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in memberIds();
      }
      // A non-member may update a trip ONLY if:
      //  • sharing is enabled on the trip (shareId is set), and
      //  • the update touches nothing but memberIds/travelerIds, and
      //  • the only id added to either list is their own uid.
      function isJoiningViaShareLink() {
        return isSignedIn()
          && resource.data.get('shareId', null) is string
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberIds', 'travelerIds'])
          && request.resource.data.memberIds.hasAll(memberIds())
          && request.resource.data.memberIds.removeAll(memberIds())
               .hasOnly([request.auth.uid])
          && request.resource.data.travelerIds.hasAll(resource.data.get('travelerIds', []))
          && request.resource.data.travelerIds.removeAll(resource.data.get('travelerIds', []))
               .hasOnly([request.auth.uid]);
      }

      allow read: if isMember();
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.get('memberIds', []);
      allow update: if isMember() || isJoiningViaShareLink();
      allow delete: if isMember();
    }

    // ── Share links — capability tokens for trip invites ────────────────
    // Doc id IS the secret: fetchable by exact id only, never listable.
    // Contains a small preview snapshot + tripId so invitees can see what
    // they're joining without any access to the trip itself.
    match /shareLinks/{shareId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isSignedIn()
        && request.auth.uid in
           get(/databases/$(database)/documents/trips/$(request.resource.data.tripId))
             .data.get('memberIds', []);
      allow delete: if isSignedIn()
        && request.auth.uid in
           get(/databases/$(database)/documents/trips/$(resource.data.tripId))
             .data.get('memberIds', []);
    }

    // ── Client error telemetry — write-only drop box ─────────────────────
    match /clientErrors/{errorId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(
             ['message', 'stack', 'context', 'url', 'userAgent', 'uid', 'createdAt'])
        && request.resource.data.message is string
        && request.resource.data.message.size() < 2000;
      allow read, update, delete: if false;
    }
  }
}
